# Copie este arquivo para .env e preencha os valores reais.
# O arquivo .env NUNCA deve ser commitado no git.

# ── Ambiente ────────────────────────────────────────────────────────────────
# "development" (padrão) ou "production"
FLASK_ENV=development

# Gere uma chave segura: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-uma-chave-secreta-aleatoria

# ── Banco de dados ──────────────────────────────────────────────────────────
# Desenvolvimento: deixe em branco (usa SQLite automático)
# Produção (Railway fornece automaticamente como DATABASE_URL):
# DATABASE_URL=postgresql://usuario:senha@host:5432/manto_db

# ── Email — Gmail Workspace via App Password ────────────────────────────────
MAIL_USERNAME=joao@mantoproducoes.com.br
MAIL_PASSWORD=xxxx xxxx xxxx xxxx
MAIL_SENDER_NAME=Sistema Manto

# ── Portal ──────────────────────────────────────────────────────────────────
# Desenvolvimento: http://localhost:5000
# Produção Railway: https://manto.up.railway.app (ou seu domínio)
PORTAL_URL=http://localhost:5000

# ── Google OAuth (Google Calendar) ─────────────────────────────────────────
# Deve ser registrada no Google Cloud Console → APIs → Credenciais
# Desenvolvimento: http://localhost:5000/oauth2callback
# Produção Railway: https://manto.up.railway.app/oauth2callback
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5000/oauth2callback

# ── Cloudflare R2 (uploads em produção) ─────────────────────────────────────
# Em desenvolvimento, USE_S3=false usa disco local (instance/uploads/)
# Em produção, USE_S3=true envia para Cloudflare R2
#
# Como obter:
# 1. dash.cloudflare.com → R2 → Create bucket (ex: manto-uploads)
# 2. R2 → Manage R2 API Tokens → Create token (Admin Read & Write)
# 3. Copie Account ID, Access Key ID e Secret Access Key
# 4. No bucket → Settings → Public access → Enable → copie a URL pública
USE_S3=false
S3_BUCKET=manto-uploads
S3_ENDPOINT_URL=https://<SEU_ACCOUNT_ID>.r2.cloudflarestorage.com
S3_PUBLIC_URL=https://pub-<HASH>.r2.dev
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
